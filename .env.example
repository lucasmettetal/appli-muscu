# Synchro cloud Supabase (optionnelle).
# Copier ce fichier en `.env.local` et remplir les valeurs pour activer la synchro.
# Sans ces variables, l'app fonctionne en mode local (profils navigateur).
#
# Ces deux valeurs sont publiques (destinées au navigateur) : Supabase → Project
# Settings → API → "Project URL" et "anon public" key.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
